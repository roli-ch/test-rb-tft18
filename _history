ml>","main.ts":"// Initialize TFT Display\nRBTFT18.init()\n// Clear screen - replaces whole screen with a black rectangle\nRBTFT18.clearScreen()\n// Draw a single red pixel\nRBTFT18.drawPixel(10, 10, Color.White)\n//showTest()\n\ninput.onButtonPressed(Button.A, function () {\n    basic.showString(\"A\")\n    \n    basic.pause(1000)\n    // Turn off display\n    RBTFT18.turnOff()\n    basic.pause(1000)\n    // Turn on display\n    RBTFT18.turnOn()\n    basic.showIcon(IconNames.Yes)\n})\n\ninput.onButtonPressed(Button.B, function () {\n    basic.showString(\"B\")\n    showTest()\n    basic.showIcon(IconNames.Yes)\n})\n\nfunction showTest() {\n    // Draw a single red pixel\n    RBTFT18.drawPixel(10, 10, Color.Red)\n    basic.pause(1000)\n    // Draw a straight blue line\n    RBTFT18.drawLine(\n        0,\n        0,\n        100,\n        100,\n        Color.Blue\n    )\n    basic.pause(1000)\n    // Draw a yellow rectangle\n    RBTFT18.drawRectangle(\n        0,\n        0,\n        100,\n        120,\n        Color.Yellow\n    )\n    basic.pause(1000)\n    // Draw a green circle\n    RBTFT18.drawCircle(\n        50,\n        50,\n        50,\n        Color.Green\n    )\n    basic.pause(1000)\n    // Clear screen - replaces whole screen with a black rectangle\n    RBTFT18.clearScreen()\n    // Show white text with black background\n    RBTFT18.showString(\n        \"I am your RB-TFT1.8!\",\n        10,\n        10,\n        1,\n        Color.White,\n        Color.Black\n    )\n    basic.pause(1000)\n    // Turn off display\n    RBTFT18.turnOff()\n    basic.pause(1000)\n    // Turn on display\n    RBTFT18.turnOn()\n}\n\n\n\n","README.md":"","main.py":"\n","pxt.json":"{\n    \"name\": \"TFT-LCD-Test\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"RB-TFT1.8\": \"github:joy-it/pxt-RB-TFT1.8#1.0.6\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\